{
  "expo": {
    "name": "PackPal",
    "slug": "packpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "packpal",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0EA5E9"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.packpal.mobile",
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"],
        "NSLocationWhenInUseUsageDescription": "PackPal uses your location to remind you of forgotten items when you leave home.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PackPal monitors when you leave home to trigger departure packing reminders."
      }
    },
    "android": {
      "package": "app.packpal.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0EA5E9"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PackPal monitors when you leave home to trigger departure packing reminders."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "demoUserId": ""
    }
  }
}
