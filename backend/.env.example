# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/packpal?schema=public"

# Port the Express server listens on
PORT=4000

# OpenWeatherMap API key (https://openweathermap.org/api).
# Optional: if unset, the packing engine still works but skips weather-based suggestions.
OPENWEATHER_API_KEY=""

# Base URL for the OpenWeatherMap REST API (rarely needs changing)
OPENWEATHER_BASE_URL="https://api.openweathermap.org"

# Simple dev auth: header used to identify the current user (see src/middleware/auth.ts).
# In production replace this with real JWT/session auth.
DEV_USER_HEADER="x-user-id"
